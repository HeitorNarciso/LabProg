{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar C (Rigoroso)",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-g",
                "*.c",
                "-o",
                "${input:nomeExecutavel}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "nomeExecutavel",
            "type": "promptString",
            "description": "Nome do executavel (sem .exe)",
            "default": "greentrack"
        }
    ]
}